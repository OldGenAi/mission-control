# Mission Control gateway — environment template.
#
# Copy this to gateway/.env and fill in the values. The gateway reads these on
# FIRST boot only; after that ~/.missioncontrol/settings.json is authoritative.
# To change a value later, edit it in the Settings UI or in settings.json.

# HMAC secret for pipeline approval gate resume tokens. Must be >= 32 chars.
# Generate with: openssl rand -hex 32
APPROVAL_SECRET=

# Local provider (LM Studio / Ollama / llama.cpp). Loopback only.
# Inside Docker on WSL2 mirrored mode, use 127.0.0.1 — NOT the WSL bridge IP.
LOCAL_PROVIDER_URL=http://127.0.0.1:1234/v1

# Default model the gateway boots with. Exact ID as the provider exposes it.
DEFAULT_MODEL=local-model

# Brave Search API key — used by the web_search tool.
SEARCH_API_KEY=

# Provider mode for the initial Instance. One of: local | openrouter | anthropic.
# After first boot you can add more Instances via the UI (each picks its own
# provider). Anthropic adapter not wired in this build yet.
PROVIDER=local

# OpenRouter API key — required if PROVIDER=openrouter, optional otherwise.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Anthropic API key — reserved for when the Anthropic adapter ships.
ANTHROPIC_API_KEY=

# Gateway listen host. Default 127.0.0.1 (loopback only).
# Set to 0.0.0.0 in Docker so the container port is reachable from the host.
GATEWAY_HOST=127.0.0.1
