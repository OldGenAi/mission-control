{
  "name": "mission-control-gateway",
  "version": "0.1.0",
  "description": "Mission Control — Node.js WebSocket gateway",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --env-file=.env node_modules/.bin/tsx watch src/index.ts",
    "build": "tsc && mkdir -p dist/agents/specs && cp src/agents/specs/*.md dist/agents/specs/ && mkdir -p dist/pipelines && cp src/pipelines/*.yaml dist/pipelines/",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "better-sqlite3": "^9.6.0",
    "express": "^4.19.2",
    "js-yaml": "^4.1.0",
    "jsonrepair": "^3.14.0",
    "openai": "^4.52.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
